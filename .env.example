# Environment variables for Bachata Dance Studio (Django)

# Django secret key (change this to a random string in production)
SECRET_KEY=your-secret-key-here-generate-using-django-secret-key-generator

# Debug mode (set to False in production)
DEBUG=False

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# Database URL (optional). Defaults to SQLite if unset.
# Examples:
# DATABASE_URL=postgresql://username:password@hostname:5432/database_name
# DATABASE_URL=mysql://username:password@hostname:3306/database_name
# For MySQL install: pip install mysqlclient

# Google Sheets Integration
GOOGLE_CREDENTIALS_FILE=json/service-account-key.json
GOOGLE_SHEET_ID=1qQmuq6mGfYuL0tvRCSp0ynMcRc9lzr0jJxRxyA0FQic
GOOGLE_SHEET_OWNER_EMAIL=your-email@example.com
